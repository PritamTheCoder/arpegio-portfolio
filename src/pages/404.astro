---
import Base from '../layouts/Base.astro'
---

<Base title="Page not found" description="That page doesn't exist.">
  <div class="container page-head" style="padding-block: var(--s-10)">
    <p class="hero__role mono">404</p>
    <h1 class="page-head__title">Page not found</h1>
    <p class="page-head__lead">
      The page you're looking for doesn't exist or has moved.
    </p>
    <p style="margin-top: var(--s-5)">
      <a class="btn btn--primary" href="/">Back home</a>
    </p>
  </div>
</Base>
