---
import { Icon } from 'astro-icon/components'
import { profile } from '../content/profile'
import Section from './Section.astro'
import Reveal from './Reveal.astro'

const { links } = profile
---

<Section id="contact" eyebrow="07 — Contact" title="Let's connect">
  <Reveal>
    <p class="contact__lead">{profile.ending}</p>
    <div class="contact__actions">
      <a class="btn btn--primary" href={`mailto:${links.email}`}>
        <Icon name="lucide:mail" /> Email
      </a>
      <a class="btn" href={links.github} target="_blank" rel="noreferrer">
        <Icon name="lucide:github" /> GitHub
      </a>
      <a class="btn" href={links.linkedin} target="_blank" rel="noreferrer">
        <Icon name="lucide:linkedin" /> LinkedIn
      </a>
    </div>
  </Reveal>
</Section>
