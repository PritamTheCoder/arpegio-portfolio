---
import Reveal from './Reveal.astro'

interface Props {
  id: string
  eyebrow: string
  title: string
}
const { id, eyebrow, title } = Astro.props
const headingId = `${id}-title`
---

<section id={id} class="section" aria-labelledby={headingId}>
  <div class="container">
    <Reveal>
      <p class="section__eyebrow">{eyebrow}</p>
      <h2 id={headingId} class="section__title">{title}</h2>
    </Reveal>
    <slot />
  </div>
</section>
