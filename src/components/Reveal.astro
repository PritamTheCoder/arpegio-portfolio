---
interface Props {
  delay?: number
  as?: keyof HTMLElementTagNameMap
  class?: string
}
const { delay = 0, as = 'div', class: className = '' } = Astro.props
const Tag = as as any
const style = delay ? `transition-delay:${delay}ms` : undefined
---

<Tag class:list={['reveal', className]} style={style}>
  <slot />
</Tag>
