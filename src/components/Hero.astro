---
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import { profile } from '../content/profile'
import Reveal from './Reveal.astro'
import portrait from '../../assets/optimized/profile-picture.webp'

const { links } = profile
---

<section class="hero" id="top">
  <div class="container hero__grid">
    <div class="hero__text">
      <Reveal><p class="hero__role mono">{profile.role}</p></Reveal>
      <Reveal delay={60}><h1 class="hero__title">{profile.name}</h1></Reveal>
      <Reveal delay={120}><p class="hero__subtitle">{profile.tagline}</p></Reveal>
      <Reveal delay={180}>
        <div class="hero__cta">
          <a class="btn btn--primary" href="#projects">
            View Projects <Icon name="lucide:arrow-right" />
          </a>
          <a class="btn" href="#contact">Get in touch</a>
        </div>
      </Reveal>
      <Reveal delay={240}>
        <div class="hero__socials">
          <a class="inline-link" href={links.github} target="_blank" rel="noreferrer">
            <Icon name="lucide:github" /> GitHub
          </a>
          <a class="inline-link" href={links.linkedin} target="_blank" rel="noreferrer">
            <Icon name="lucide:linkedin" /> LinkedIn
          </a>
          <a class="inline-link" href={`mailto:${links.email}`}>
            <Icon name="lucide:mail" /> Email
          </a>
        </div>
      </Reveal>
    </div>

    <Reveal delay={120} class="hero__portrait-wrap">
      <Image
        class="hero__portrait"
        src={portrait}
        widths={[200, 300, 600]}
        sizes="(max-width: 720px) 150px, 300px"
        alt={`${profile.name}, ${profile.role}`}
        loading="eager"
      />
    </Reveal>
  </div>
</section>
